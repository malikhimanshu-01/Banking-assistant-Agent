{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DEV - Banking Web App",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "cwd": "${workspaceFolder}/app/frontend/banking-web",
            "preLaunchTask": "npm install - banking-web",
            "console": "integratedTerminal"
        },
       
        {
            "name": "DevUI",
            "type": "debugpy",
            "request": "launch",
            "program": "app/main_dev-ui.py",
            "env": {
                "PROFILE": "dev",
                "PYTHONNOUSERSITE": "1"
            },
            "jinja": true,
            "cwd": "${workspaceFolder}/app/backend",
            "justMyCode": true

        },
         
        {
            "name": "DEV - Chatkit Backend App",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main_chatkit_server:app",
                "--port", "8080"
            ],
            "env": {
                "PROFILE": "dev",
                "ENABLE_SENSITIVE_DATA": "true"
            },
            "jinja": true,
            "cwd": "${workspaceFolder}/app/backend",
            "justMyCode": false

        },
        {
            "name": "No Profile - Custom Chat Server",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "python": "./app/backend/.venv/Scripts/python.exe",
            "args": [
                "app.main_handoff:app",
                "--port", "8080"
            ],
            "env": {
                "AGENT_FRAMEWORK_ENABLE_OTEL": "true"
            },
            "jinja": true,
            "cwd": "${workspaceFolder}/app/backend",
            "justMyCode": false

        }
       
    ]
}
